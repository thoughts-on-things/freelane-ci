{
  "name": "freelane-ci",
  "version": "0.2.0",
  "description": "Route GitHub Actions jobs across CI runner providers to use free credits first.",
  "license": "MIT",
  "private": false,
  "packageManager": "npm@11.16.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "freelane": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "schemas",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsup && tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm test && npm run build",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-actions",
    "ci",
    "ci-cd",
    "runners",
    "cost-optimization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thoughts-on-things/freelane-ci.git"
  },
  "bugs": {
    "url": "https://github.com/thoughts-on-things/freelane-ci/issues"
  },
  "homepage": "https://github.com/thoughts-on-things/freelane-ci#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "ajv": "^8.20.0",
    "yaml": "^2.8.1"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
